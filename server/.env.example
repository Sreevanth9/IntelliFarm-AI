PORT=5001
NODE_ENV=development
ACCESS_TOKEN_JWT_SECRET=replace_with_a_unique_32_character_minimum_access_secret
REFRESH_TOKEN_JWT_SECRET=replace_with_a_different_unique_32_character_minimum_refresh_secret
ACCESS_TOKEN_EXPIRETIME=15m
REFRESH_TOKEN_EXPIRETIME=7d
JWT_ISSUER=intellifarm-api
JWT_AUDIENCE=intellifarm-web
GROQ_API_KEY=your_groq_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here
